# =============================================================================
# PISANG VAN JAVA — ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
# ⚠️ FILE INI ADALAH TEMPLATE SAJA — TIDAK MENGANDUNG SECRET REAL
# ⚠️ PRODUCTION: Semua variabel disuntikkan otomatis oleh Doppler → Vercel
#
# CARA SETUP LOKAL:
# Opsi A (Rekomendasi): doppler run -- pnpm dev
# Opsi B (Manual): cp .env.example .env.local && isi nilainya
# =============================================================================

NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Auth
NEXTAUTH_SECRET=GENERATE_DENGAN_openssl_rand_-base64_32
NEXTAUTH_URL=http://localhost:3000
SESSION_SECRET=GENERATE_DENGAN_openssl_rand_-base64_32
AUTH_GOOGLE_ID=[GOOGLE_ID]
AUTH_GOOGLE_SECRET=[GOOGLE_SECRET]

# Redis
UPSTASH_REDIS_REST_URL=https://[DATABASE-NAME].upstash.io
UPSTASH_REDIS_REST_TOKEN=A[...]

# Supabase Server
SUPABASE_SERVICE_ROLE_KEY=eyJ[...]
SUPABASE_ACCESS_TOKEN=sbp_[...]
SUPABASE_JWT_SECRET=[...]

# Midtrans Server
MIDTRANS_SERVER_KEY=SB-Mid-server-[...]
MIDTRANS_MERCHANT_ID=M[...]

# Integrations
RESEND_API_KEY=re_[...]
OPENAI_API_KEY=sk-[...]
SENTRY_AUTH_TOKEN=sntrys_[...]

# App Config (Public)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_WA_NUMBER=+62[...]

# Supabase Client
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ[...]
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_[...]

# Midtrans Client
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-[...]
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# BiteShip Sandbox (Delivery Logistics)
# Dapatkan API key Sandbox Anda dari https://biteship.com/id/docs/api/rates/overview
BITESHIP_API_KEY=biteship_test_eyJ[...]

