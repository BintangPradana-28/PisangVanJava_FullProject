{
  "$schema": "https://raw.githubusercontent.com/secretlint/secretlint/master/packages/@secretlint/config-schema/secretlint-config.schema.json",
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend",
      "options": {
        "allows": []
      }
    },
    {
      "id": "@secretlint/secretlint-rule-no-dotenv",
      "options": {
        "allows": [
          "**/.env.example",
          "**/.env.test"
        ]
      }
    }
  ],
  "ignores": [
    ".env.example",
    ".env.test",
    "node_modules/**",
    ".next/**",
    "dist/**",
    "coverage/**",
    "**/*.md"
  ]
}
